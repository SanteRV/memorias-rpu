# === Variables para Vercel (configurar en el dashboard del proyecto) ===

# Inyectada automáticamente al conectar Neon/Postgres desde el Marketplace de Vercel
# DATABASE_URL=postgres://usuario:contraseña@host/db?sslmode=require

# Inyectada automáticamente al conectar un Blob store (fotos antiguas)
# BLOB_READ_WRITE_TOKEN=

# Cloudinary: almacenamiento de las fotos nuevas.
# Valores en https://console.cloudinary.com/app/settings/api-keys
# NUNCA pegar los valores reales aquí: van cifrados en Vercel.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Clave para operaciones de administración (DELETE). Generar una aleatoria:
# openssl rand -hex 32
ADMIN_API_KEY=

# === Opcional (solo si la API vive en otro dominio; por defecto usa /api) ===
# VITE_API_URL=/api
